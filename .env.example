# OpenRouter API key for LLM OCR cleanup (optional, but highly recommended)
# Get one at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cloudflare Tunnel Token for production deployment via docker-compose (optional for local dev)
# Set this in your host environment before running docker compose up in production
# CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
